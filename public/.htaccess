Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# Serve existing files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Serve a directory index.html if present
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^ %{REQUEST_URI}/index.html [L]

# Special case: /shop should serve its page
RewriteCond %{REQUEST_URI} ^/shop/?$
RewriteCond %{DOCUMENT_ROOT}/shop/index.html -f
RewriteRule ^ /shop/index.html [L]
RewriteCond %{DOCUMENT_ROOT}/shop.html -f
RewriteRule ^ /shop.html [L]

# If a .html version of the requested path exists, serve it
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Fallback to static 404
RewriteRule ^.*$ /404.html [L]
